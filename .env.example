# JourneyAI backend — copy this file to ".env" and fill in the values.

# Anthropic API key — REQUIRED. Powers transport-mode discovery (Claude) and
# the per-stay day optimizer.
# Get one at https://console.anthropic.com  (Settings -> API Keys). Pay-as-you-go,
# ~$0.003 per transport lookup.
ANTHROPIC_API_KEY=

# FlightAPI.io key — OPTIONAL but recommended: gives REAL flight schedules and
# fares (departure/arrival times, flight numbers, airlines).
# Self-serve signup at https://www.flightapi.io  — free tier is 20 API calls,
# then $49/mo for 30k credits. Without this, flights fall back to Claude
# estimates; every other screen still works.
FLIGHTAPI_KEY=

# Port the backend listens on.
PORT=4000
