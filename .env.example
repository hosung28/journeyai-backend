# JourneyAI backend — copy this file to ".env" and fill in the values.

# Anthropic API key — REQUIRED. Powers transport-mode discovery (Claude) and
# the per-stay day optimizer.
# Get one at https://console.anthropic.com  (Settings -> API Keys). Pay-as-you-go,
# ~$0.003 per transport lookup.
ANTHROPIC_API_KEY=

# FlightAware AeroAPI key — OPTIONAL but recommended: gives REAL airline
# schedule data (departure/arrival times in airport-local time, real flight
# numbers, real airlines, dedup'd codeshares, cargo flights filtered).
# Self-serve at https://www.flightaware.com/commercial/aeroapi/  — $5/month
# free credit, $0.005-$0.02 per schedule lookup. Without this, flights fall
# back to Claude estimates; every other screen still works.
#
# Set a monthly billing cap in the FlightAware portal to never exceed $5.
AEROAPI_KEY=

# Port the backend listens on.
PORT=4000
