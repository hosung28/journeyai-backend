# JourneyAI backend — copy this file to ".env" and fill in the values.

# Anthropic API key — REQUIRED. Powers transport-mode discovery (Claude).
# Get one at https://console.anthropic.com  (Settings -> API Keys). Pay-as-you-go,
# ~$0.003 per transport lookup.
ANTHROPIC_API_KEY=

# Amadeus Self-Service — OPTIONAL but recommended: gives REAL flight fares.
# Free sandbox keys, instant signup: https://developers.amadeus.com
#   -> My Self-Service Workspace -> create a new app -> copy the API Key + Secret.
# Without these, flights fall back to Claude estimates; everything else still works.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Port the backend listens on.
PORT=4000
